# NetMon Web Configuration
# Copy this file to .env and customize as needed

# Network Configuration
NETMON_IP_PREFIX=10.100
NETMON_START_SUBNET=64
NETMON_END_SUBNET=171
NETMON_SCAN_IP_START=1
NETMON_SCAN_IP_END=254

# Scan Settings
NETMON_SCAN_MODE=ping
NETMON_TCP_PORT=22
NETMON_RETRY_COUNT=2
NETMON_REFRESH_INTERVAL=120
NETMON_SUBNETS_PER_GROUP=4

# Web Settings
NETMON_WEB_PORT=80
NETMON_DEBUG=false

# Optional: API Authentication
# Uncomment and set to enable API key protection
# NETMON_API_KEY=your-secret-api-key-here
